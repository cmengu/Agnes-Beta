# AgnesOps — copy to `.env` and fill in values. Never commit `.env`.

# --- ZenMux / Agnes (OpenAI-compatible SDK) ---
# https://zenmux.ai dashboard — used as OpenAI client `api_key` + `base_url`.
ZENMUX_API_KEY=
ZENMUX_BASE_URL=https://zenmux.ai/api/v1
# e.g. sapiens-ai/agnes-1.5-pro or sapiens-ai/agnes-1.5-lite
LLM_MODEL=sapiens-ai/agnes-1.5-pro

# --- Web search (Phase 3) ---
# One of: serper | tavily | serpapi — set the matching key below.
SEARCH_PROVIDER=serper
SERPER_API_KEY=
TAVILY_API_KEY=
SERPAPI_API_KEY=

# --- Telegram (Phase 4 / OpenClaw) ---
# @BotFather — e.g. openclaw config set telegram_token <value>
TELEGRAM_BOT_TOKEN=
# Base URL for telegram_bridge.py (local or public after tunnel/deploy)
AGNES_API_BASE=http://127.0.0.1:8000
# Telegram: 1 = text each backend status line from /run/stream (default); 0 = only final report
# TELEGRAM_LIVE_STATUS=1
# Max seconds to wait for /run or /run/stream (default 900)
# AGNES_RUN_TIMEOUT_SEC=900

# --- Critic (plan default) ---
CRITIC_SCORE_THRESHOLD=0.75

# --- Optional: JS-heavy fetch (install requirements-playwright.txt + playwright install chromium) ---
# USE_PLAYWRIGHT_FETCH=0
