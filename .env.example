# AgnesOps — copy to `.env` and fill in values (never commit `.env`).

# --- ZenMux / Agnes (OpenAI-compatible SDK) ---
# Dashboard: https://zenmux.ai — key used as `api_key` with base URL below.
ZENMUX_API_KEY=
ZENMUX_BASE_URL=https://zenmux.ai/api/v1
LLM_MODEL=sapiens-ai/agnes-1.5-pro

# --- Web search (Phase 3) ---
# Set exactly one provider: serper | tavily | serpapi
SEARCH_PROVIDER=serper
SERPER_API_KEY=
TAVILY_API_KEY=
SERPAPI_API_KEY=

# --- Telegram (Phase 4 / OpenClaw) ---
# From @BotFather. OpenClaw may use: openclaw config set telegram_token <value>
TELEGRAM_BOT_TOKEN=

# --- Critic loop (plan default 0.75) ---
CRITIC_SCORE_THRESHOLD=0.75
